{
  "manifest_version": 3,
  "name": "Bookmark REST Controller",
  "description": "Executes bookmark commands from a local unauthenticated REST command queue.",
  "version": "0.1.0",
  "permissions": ["bookmarks", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1:8877/*", "http://localhost:8877/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Bookmark REST Controller",
    "default_popup": "popup.html"
  }
}
